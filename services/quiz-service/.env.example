# quiz-service dizinine kopyala: cp .env.example .env
#
# Önce veritabanı oluştur:  CREATE DATABASE quiz;
#
# Şifre yoksa (ör. trust): aşağıdaki satır yeterli.
# Şifre varsa: postgresql+asyncpg://postgres:SIFREN@localhost:5432/quiz
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/quiz

# Örnek: SQLite
# DATABASE_URL=sqlite+aiosqlite:///./quiz.db
