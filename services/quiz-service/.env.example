# quiz-service dizinine kopyala: cp .env.example .env
#
# Önce veritabanı oluştur:  CREATE DATABASE quiz;
#
# Şifre yoksa (ör. trust): aşağıdaki satır yeterli.
# Şifre varsa: postgresql+asyncpg://postgres:SIFREN@localhost:5432/quiz
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/quiz

# production ortamında iç sunucu hata mesajları gizlenir
ENVIRONMENT=development

# JWT — production'da mutlaka güçlü bir değer verin (örn. openssl rand -hex 32)
JWT_SECRET=dev-only-change-me-use-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=480

# İlk yönetici hesabı: users tablosu BOŞKEN bir kez oluşturulur; sonra bu satırları .env'den kaldırabilirsiniz.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=buraya-guclu-sifre

# Örnek: SQLite
# DATABASE_URL=sqlite+aiosqlite:///./quiz.db
